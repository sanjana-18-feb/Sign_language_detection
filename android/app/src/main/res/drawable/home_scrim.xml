<?xml version="1.0" encoding="utf-8"?>
<!-- Transparent at the top fading to near-opaque dark at the bottom, so the
     title and buttons stay readable over the background image. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:angle="90"
        android:startColor="#00070B12"
        android:centerColor="#99070B12"
        android:endColor="#F2070B12" />
</shape>
